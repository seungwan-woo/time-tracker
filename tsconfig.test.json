{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "Node16",
    "moduleResolution": "node16",
    "noEmit": false,
    "outDir": ".test-dist",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["lib/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
